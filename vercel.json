{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/egitimde-yapay-zeka-maarif-modeli.html",
      "destination": "/egitimde-yapay-zeka-maarif-modeli",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}